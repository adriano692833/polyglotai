# OPENROUTER_API_KEY: Required for AI features (free at openrouter.ai)
OPENROUTER_API_KEY="your-openrouter-api-key"

# OPENROUTER_MODEL: AI model to use via OpenRouter (optional, can change without redeploying)
# Browse free models at: https://openrouter.ai/models?q=:free
OPENROUTER_MODEL="minimax/minimax-m2.5:free"

# DATABASE_URL: PostgreSQL connection string.
# Get a free database at https://neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"
